        "description": "是否启用封面模糊处理",
        "type": "bool"
    },
    "blur_radius": {
        "description": "封面模糊处理的模糊半径",
        "type": "int",
        "default": 10
    },
    "blur_area_ratio": {
        "description": "封面模糊处理的模糊区域占比（0-1之间的小数）",
        "type": "float",
        "default": 0.5
    }
